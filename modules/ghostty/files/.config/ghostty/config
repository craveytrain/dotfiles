# Ghostty Configuration

# Font Configuration
font-family = MonoLisa Variable
font-size = 14
font-style = Medium

theme = "Gruvbox Dark Hard"

# Additional Settings
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = tabs

window-inherit-font-size = true
copy-on-select = clipboard
keybind = shift+enter=text:\x1b\r

# Bell behavior - persistent tab badge + dock bounce when unfocused
bell-features = attention,title
